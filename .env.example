APP_NAME=webhook-manager
DEBUG=false

# Keep these in sync with `.env` keys.
DATABASE_URL=postgresql+asyncpg://webhook_manager:webhook_manager@postgres:5432/webhook_manager
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0

SECRET_KEY=your-secret-key-minimum-32-characters-here
LOG_LEVEL=INFO

RATE_LIMIT_INGEST=100
RATE_LIMIT_READ=1000
MAX_DELIVERY_ATTEMPTS=5
DELIVERY_TIMEOUT_SECONDS=10

SENTRY_DSN=

